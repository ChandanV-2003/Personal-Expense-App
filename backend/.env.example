PORT=5000
MONGO_URI=
FRONTEND_URL=http://localhost:5173,https://your-frontend-domain.com
JWT_SECRET=

# Email / SMTP settings
EMAIL_USER=
EMAIL_PASS=
MAIL_FROM=
BREVO_API_KEY=

# Optional: custom SMTP provider
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=
# SMTP_PASS=

# If SMTP_HOST is omitted, the backend will try Gmail SMTP on 465 and then 587.
# If BREVO_API_KEY is set, backend uses Brevo HTTPS API first (recommended on Render).

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AI bill parsing
DEEPSEEK_API_KEY=
DEEPSEEK_ENDPOINT=https://api.deepseek.com/v1/chat/completions
